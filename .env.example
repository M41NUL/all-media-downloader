# ============================================
# All Media Downloader Bot — Environment Variables
# Developer: Md. Mainul Islam (MAINUL-X)
# GitHub   : https://github.com/M41NUL
# ============================================

# [REQUIRED] Your Telegram Bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# [REQUIRED] Full public URL of your deployed app (no trailing slash)
# Example for Render: https://all-media-downloader.onrender.com
WEBHOOK_URL=https://your-app-name.onrender.com

# [OPTIONAL] Your Telegram user ID — grants /admin access
# Get your ID from @userinfobot on Telegram
ADMIN_ID=123456789

# [OPTIONAL] Port — Render sets this automatically, leave as 3000 for local dev
PORT=3000

# [OPTIONAL] RapidAPI key — used as Instagram fallback
# Get a free key at https://rapidapi.com
RAPIDAPI_KEY=
